# Configuração no /etc/nginx/nginx.conf
# Bloco stream { } fica FORA do bloco http { }

user www-data;
worker_processes auto;
pid /run/nginx.pid;
include /etc/nginx/modules-enabled/*.conf;

events {
    worker_connections 768;
    # multi_accept on;
}

http {
    ##
    # Basic Settings
    ##

    sendfile on;
    tcp_nopush on;
    types_hash_max_size 2048;
    # server_tokens off;

    # server_names_hash_bucket_size 64;
    # server_name_in_redirect off;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    ##
    # SSL Settings
    ##

    ssl_protocols TLSv1 TLSv1.1 TLSv1.2 TLSv1.3; # Dropping SSLv3, ref: POODLE
    ssl_prefer_server_ciphers on;

    ##
    # Logging Settings
    ##

    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    ##
    # Gzip Settings
    ##

    gzip on;

    # gzip_vary on;
    # gzip_proxied any;
    # gzip_comp_level 6;
    # gzip_buffers 16 8k;
    # gzip_http_version 1.1;
    # gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    ##
    # Virtual Host Configs
    ##

    include /etc/nginx/conf.d/*.conf;
    # include /etc/nginx/sites-enabled/*;
}
stream {
    # Formato dos logs
    log_format proxy '$remote_addr - $ssl_preread_server_name [$time_local] '
                     '$protocol $status $bytes_sent $bytes_received '
                     '$session_time';
    access_log /var/log/nginx/stream_access.log proxy;

    ###########################################################################
    # Mapeamento baseado no SNI (443) — apenas para conexões TLS
    ###########################################################################
    map $ssl_preread_server_name $backend_name_443 {
        sentry.sittax.com.br sentry;
        default allDefault;
    }

    ###########################################################################
    # Upstreams
    ###########################################################################
    upstream sentry {
        server 192.168.1.201:443;
    }

    upstream allDefault {
        server 192.168.1.116:443;
    }


    ###########################################################################
    # Porta 443 — TLS passthrough com SNI
    ###########################################################################
    server {
        listen 443;
        proxy_pass $backend_name_443;
        ssl_preread on;
    }

    ###########################################################################
    # Porta 80 — TCP proxy simples (sem TLS)
    ###########################################################################
    map $server_addr $backend_name_80 {
        sentry.sittax.com.br sentry_http;
        default allDefault_http;
    }

    upstream sentry_http {
        server 192.168.1.201:80;
    }

    upstream allDefault_http {
        server 192.168.1.116:80;
    }


    # Se quiser usar hostname também (como o do 443)
    # você pode mapear por IP, já que $ssl_preread_server_name não funciona aqui.
    server {
        listen 80;
        # Encaminha tudo da porta 80 para o IP 201
        proxy_pass sentry_http;
        # Não use ssl_preread aqui
    }
}

