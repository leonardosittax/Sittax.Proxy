# Configuração no /etc/nginx/nginx.conf
# Bloco stream { } fica FORA do bloco http { }

user www-data;
worker_processes auto;
pid /run/nginx.pid;
include /etc/nginx/modules-enabled/*.conf;

events {
    worker_connections 768;
    # multi_accept on;
}

http {
    ##
    # Basic Settings
    ##

    include /etc/nginx/upstream_http.conf;
    
    sendfile on;
    tcp_nopush on;
    types_hash_max_size 2048;
    # server_tokens off;

    # server_names_hash_bucket_size 64;
    # server_name_in_redirect off;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    ##
    # SSL Settings
    ##

    ssl_protocols TLSv1 TLSv1.1 TLSv1.2 TLSv1.3; # Dropping SSLv3, ref: POODLE
    ssl_prefer_server_ciphers on;

    ##
    # Logging Settings
    ##

    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    ##
    # Gzip Settings
    ##

    gzip on;

    # gzip_vary on;
    # gzip_proxied any;
    # gzip_comp_level 6;
    # gzip_buffers 16 8k;
    # gzip_http_version 1.1;
    # gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    ##
    # Virtual Host Configs
    ##

    include /etc/nginx/conf.d/*.conf;
    # include /etc/nginx/sites-enabled/*;
    log_format http_detailed '[$time_local] '
                             'Host: $host | '
                             'Client: $remote_addr | '
                             'CF-IP: $http_cf_connecting_ip | '
                             'X-Forwarded-For: $http_x_forwarded_for | '
                             'Backend: $backend_name_http | '
                             'Method: $request_method | '
                             'URI: $request_uri | '
                             'Status: $status | '
                             'Size: $body_bytes_sent bytes | '
                             'Referer: "$http_referer" | '
                             'User-Agent: "$http_user_agent" | '
                             'Request-Time: ${request_time}s | '
                             'Upstream: $upstream_addr | '
                             'Upstream-Time: ${upstream_response_time}s';
    server {
        listen 127.0.0.1:8080;

        access_log /var/log/nginx/http_router.access.log http_detailed;
        error_log /var/log/nginx/http_router.error.log;
	location / {
            proxy_pass http://$backend_name_http;

            # Headers essenciais
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto https;  # Cloudflare usa HTTPS
            proxy_set_header X-Forwarded-Host $host;

            # Headers do Cloudflare
            proxy_set_header CF-Connecting-IP $http_cf_connecting_ip;
            proxy_set_header CF-Ray $http_cf_ray;

            # Timeouts
            proxy_connect_timeout 600;
            proxy_send_timeout 600;
            proxy_read_timeout 600;
            send_timeout 600;

            # WebSocket support
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
	}

    }
}
stream {
    ###########################################################################
    # Formato de logs para stream (TCP/UDP - sem variáveis HTTP)
    ###########################################################################

    include /etc/nginx/upstream_https.conf;
    log_format stream_proxy '[$time_local] '
                            'Protocol: $protocol | '
                            'Client: $remote_addr:$remote_port | '
                            'Backend: $server_addr:$server_port | '
                            'Upstream: $upstream_addr | '
                            'Bytes Sent: $bytes_sent | '
                            'Bytes Received: $bytes_received | '
                            'Session Time: $session_time s | '
                            'Status: $status';

    # Servidor HTTPS com TLS passthrough
    server {
        listen 443;
        listen [::]:443;

	#listen 443 proxy_protocol;
        #listen [::]:443 proxy_protocol;
        access_log /var/log/nginx/stream_https.access.log stream_proxy;
        error_log /var/log/nginx/stream_https.error.log;

	#proxy_protocol on;
        proxy_pass $backend_name_https;
        ssl_preread on;
    }

    ###########################################################################
    # Porta 80 — TCP proxy com roteamento
    ###########################################################################

    # IMPORTANTE: No stream, não temos $host disponível
    # Vamos usar $ssl_preread_server_name mesmo na porta 80 não funciona
    # A solução é rotear TUDO para um backend que fará o roteamento HTTP

    # Opção 1: Rotear tudo para um único servidor que faz proxy HTTP
    upstream http_router {
        server 127.0.0.1:8080;  # Nginx HTTP interno que fará o roteamento
    }

    server {
        listen 80;
        listen [::]:80;

        access_log /var/log/nginx/stream_http.access.log stream_proxy;
        error_log /var/log/nginx/stream_http.error.log;

        proxy_pass http_router;
    }
}

